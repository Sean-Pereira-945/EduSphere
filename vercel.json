{
  "version": 2,
  "name": "edusphere",
  "functions": {
    "backend/server.js": {
      "includeFiles": "client/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/uploads/(.*)",
      "destination": "https://res.cloudinary.com/djwygkmsh/image/upload/v1/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/backend/server.js"
    }
  ]
}

