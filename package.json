{
  "name": "learning-platform-monorepo",
  "version": "1.0.0",
  "description": "EduSphere Virtual Learning Environment - Full Stack Monorepo",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "build:client": "npm run build --prefix client",
    "install:client": "npm install --prefix client",
    "install:backend": "npm install --prefix backend",
    "install:all": "npm install && npm run install:client && npm run install:backend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "file-type": "^21.3.3",
    "fs": "^0.0.1-security",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.2",
    "multer": "^1.4.5-lts.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
